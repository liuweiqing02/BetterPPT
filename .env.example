# BetterPPT environment template
# Copy to `source/backend/.env` for local runtime. Do not commit real secrets.

# ===== App =====
APP_ENV=dev
APP_PORT=8000
AUTH_DEFAULT_USER_ID=1

# ===== MySQL =====
# Option A: use discrete MYSQL_* variables
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=betterppt

# Option B: set DATABASE_URL to override MYSQL_* variables
# Example: mysql+pymysql://root:change_me@127.0.0.1:3306/betterppt?charset=utf8mb4
DATABASE_URL=

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== LLM API =====
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4.1-mini
# Timeout/retry guard for all LLM-driven agents in worker pipeline.
LLM_REQUEST_TIMEOUT_SECONDS=15
LLM_REQUEST_MAX_RETRIES=1

# ===== Optional Vision Embedding (Template V1.2) =====
# Model hub id (metadata); actual runtime prefers BETTERPPT_TEMPLATE_VISION_MODEL_PATH when present.
BETTERPPT_TEMPLATE_VISION_MODEL=google/vit-base-patch16-224-in21k
# Local model directory for offline/local_files_only loading.
BETTERPPT_TEMPLATE_VISION_MODEL_PATH=
# Local HuggingFace cache directory.
BETTERPPT_TEMPLATE_VISION_CACHE_DIR=

# ===== Storage =====
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage
UPLOAD_SUBDIR=uploads
RESULT_SUBDIR=results

# ===== Optional Object Storage Fields (reserved) =====
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
